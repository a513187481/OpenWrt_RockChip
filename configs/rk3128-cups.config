# 目标平台 RK3128
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv7=y
CONFIG_TARGET_rockchip_armv7_DEVICE_generic=y

# 网页后台
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y

# CUPS打印服务
CONFIG_PACKAGE_cups=y
CONFIG_PACKAGE_cups-filters=y
CONFIG_PACKAGE_luci-app-cups=y

# USB打印机驱动
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_usbutils=y

# 松下228打印机驱动
CONFIG_PACKAGE_foo2zjs=y
CONFIG_PACKAGE_foo2zjs-ppd=y
CONFIG_PACKAGE_gutenprint=y

# 打印机网页设置
CONFIG_PACKAGE_luci-app-usb-printer=y
